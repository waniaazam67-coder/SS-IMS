NODE_ENV=development
PORT=3000
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ims_system
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password_or_leave_blank
FIREBASE_API_KEY=your_public_firebase_web_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_firebase_app_id
FIREBASE_CLIENT_EMAIL=your_firebase_service_account_client_email
FIREBASE_PRIVATE_KEY=your_firebase_service_account_private_key_with_escaped_newlines
FIREBASE_MEASUREMENT_ID=your_optional_measurement_id
FIREBASE_APPCHECK_RECAPTCHA_SITE_KEY=your_optional_firebase_app_check_recaptcha_v3_site_key
CORS_ORIGIN=http://localhost:3000
ENABLE_ADMIN_SEED=false
# Firebase console production checklist:
# - Add only approved production domains under Authentication > Settings > Authorized domains.
# - Disable unused sign-in providers; this IMS currently expects Email/Password and Google only.
# - Configure Firebase Authentication abuse protections and App Check/reCAPTCHA where supported for your chosen providers.
